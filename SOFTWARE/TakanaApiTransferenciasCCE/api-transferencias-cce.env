END_POINT_INTEROPERABILIDAD_BARRIDO = #{EndPointInteroperabilidadBarrido}#,
END_POINT_INTEROPERABILIDAD_AUTORIZACION_QR = #{EndPointInteroperabilidadAutorizacionQR}#,
END_POINT_INTEROPERABILIDAD_GENERAR_QR = #{EndPointInteroperabilidadGenerarQR}#,
END_POINT_INTEROPERABILIDAD_LEER_QR = #{EndPointInteroperabilidadLeerQR}#,
END_POINT_INTEROPERABILIDAD_OBTENER_DATOS_QR = #{EndPointInteroperabilidadObtenerQR}#,
