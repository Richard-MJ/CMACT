ASPNETCORE_URLS=https://+;http://+
ASPNETCORE_HTTP_PORTS=#{PuertoExpuesto}#
ASPNETCORE_Kestrel__Certificates__Default__Path=#{CertificadoRuta}#
ASPNETCORE_Kestrel__Certificates__Default__Password=#{CertificadoPassword}#

ASPNETCORE_ENVIRONMENT=Production
TAK_BITACORA_SERVIDOR = #{BitacoraServidor}#,
TAK_BITACORA_CONSOLA = #{BitacoraConsola}#,
TAK_BD_SAF_SERVIDOR = #{BDservidor}#,
TAK_BD_SAF_CATALOGO = #{BDnombre}#,
TAK_BD_SAF_USUARIO = #{BDusuario}#,
TAK_BD_SAF_CONTRASENA = #{BDpassword}#,
TAK_BD_SAF_CERTIFICADO = #{BDcertificado}#,
TAK_BD_SAF_SEGURIDAD_INTEGRADA = #{BDseguridadIntegrada}#,
TAK_USAR_VALIDACION_SSL = #{UsarValidacionSSL}#,
TAK_USAR_ENTORNO_SEGURIDAD_CCE = #{UsarEntornoSeguridaCCE}#,
TAK_USAR_MODULO_SEGURIDAD_HARDWARE = #{UsarModuloSeguridadHardWare}#,
SERVIDOR_COLAS_IP = #{IpServidorColas}#,
SERVIDOR_COLAS_USUARIO = #{UsuarioServidorColas}#,
SERVIDOR_COLAS_CLAVE = #{ClaveServidorColas}#,
NOMBRE_CERTIFICADO_TLS_CCE = #{NombreCertificadoTLSCCE}#,
NOMBRE_CERTIFICADO_FIRMA_CCE = #{NombreCertificadoFirmaCCE}#,
NOMBRE_CERTIFICADO_TLS_CMACT = #{NombreCertificadoTLSCMACT}#,
NOMBRE_CERTIFICADO_FIRMA_CMACT = #{NombreCertificadoFirmaCMACT}#,
USUARIO_INTEROPERABILIDAD_QR = #{UsuarioInteroperabilidadQR}#,
CLAVE_INTEROPERABILIDAD_QR = #{ClaveInteroperabilidadQR}#,
URL_SERVICIO_API_INMEDIATA = #{UrlServicioApiInmediata}#,
URL_SERVICIO_API_PIN_OPERACIONES = #{UrlServicioApiPinOperaciones}#,
URL_SERVICIO_OPERADORA_CCE = #{UrlServicioOperadoraCCE}#,
URL_SERVICIO_OPERADORA_CCE_INTEROPERABILIDAD = #{UrlServicioOperadoraCCEInteroperabilidad}#,
URL_SERVICIO_OPERADORA_CCE_INTEROPERABILIDAD_BARRIDO = #{UrlServicioOperadoraCCEInteroperabilidadBarrido}#,
URL_SERVICIO_OPERADORA_CCE_INTEROPERABILIDAD_QR = #{UrlServicioOperadoraCCEInteroperabilidadQR}#,
